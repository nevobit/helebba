{
  "name": "helebba",
  "private": true,
  "author": "Nestor Mosquera <nestor@revoluc.com>",
  "license": "MIT",
  "keywords": [
    "NPM",
    "PNPM",
    "package",
    "monorepo",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nevobit/helebba.git"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:edge": "turbo run dev --parallel --concurrency=32 --filter=edge --filter='./packages/*' --filter='!@hlb/tooling'",
    "dev:packages": "turbo run dev --parallel --concurrency=32 --filter='./packages/*' --filter='!@hlb/tooling'",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24"
  }
}
